# Web3Forms API key for direct email delivery from the contact form
# 1. Register for free at https://web3forms.com by submitting your email
# 2. Paste the access key received in your email inbox below


# Supabase Configuration for shared live database (optional, fallback to localStorage)
# 1. Create a free project at https://supabase.com
# 2. Go to Project Settings -> API and copy the URL and Anon Key
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
